<view class="page">
  <view class="section">
    <view class="title">个人酒量档案</view>
    <view class="subtitle">先填最关键的信息，后面可以随时修改。</view>
  </view>

  <view class="section card">
    <view class="field">
      <view class="label">自评酒量</view>
      <picker range="{{toleranceOptions}}" value="{{toleranceIndex}}" bindchange="onToleranceChange">
        <view class="input">{{form.toleranceLevel}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">平时喝酒频率</view>
      <picker range="{{frequencyOptions}}" value="{{frequencyIndex}}" bindchange="onFrequencyChange">
        <view class="input">{{form.drinkingFrequency}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">容易上头的酒</view>
      <input class="input" value="{{form.sensitiveAlcoholType}}" placeholder="例如：白酒" bindinput="onSensitiveInput" />
    </view>

    <view class="field">
      <view class="label">严格提醒</view>
      <switch checked="{{form.strictMode}}" bindchange="onStrictChange" />
    </view>
  </view>

  <button class="btn btn-primary" bindtap="save">保存档案</button>
</view>
