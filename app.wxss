page {
  background: #f6f7f9;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
}

.section {
  margin-bottom: 28rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 28rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
}

.label {
  color: #374151;
  font-size: 26rpx;
  font-weight: 600;
}

.value {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.muted {
  color: #6b7280;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.btn {
  margin-top: 20rpx;
  border-radius: 10rpx;
  font-size: 30rpx;
}

.btn-primary {
  background: #111827;
  color: #ffffff;
}

.btn-secondary {
  background: #ffffff;
  color: #111827;
  border: 1rpx solid #d1d5db;
}

.risk-low {
  color: #047857;
}

.risk-medium {
  color: #b45309;
}

.risk-high {
  color: #c2410c;
}

.risk-danger {
  color: #b91c1c;
}

.field {
  margin-bottom: 24rpx;
}

.input {
  margin-top: 12rpx;
  min-height: 76rpx;
  box-sizing: border-box;
  padding: 16rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid #d1d5db;
  border-radius: 10rpx;
}
